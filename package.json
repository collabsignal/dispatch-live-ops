{
  "name": "dispatch-live-ops",
  "version": "1.0.0",
  "description": "Real-time rider and delivery agent tracking challenge for CollabSignal",
  "main": "dist/server/server/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "start": "node dist/server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "collabsignal",
    "react",
    "express",
    "realtime",
    "dispatch",
    "performance",
    "sdet"
  ],
  "author": "CollabSignal",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/supertest": "^2.0.16",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^8.2.2",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
